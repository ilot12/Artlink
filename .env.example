# ArtLink 환경 변수 예시
# 이 파일을 복사하여 .env로 사용하세요

# Database (PostgreSQL)
DATABASE_URL="postgresql://artlink:artlink_dev_password@localhost:5432/artlink"
# 배포 예시: DATABASE_URL="postgresql://user:pass@rds-endpoint:5432/artlink"

# JWT
JWT_SECRET="your-secret-key-here"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# File Upload
UPLOAD_DIR="uploads"
