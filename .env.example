# ArtLink 환경 변수 예시
# 이 파일을 복사하여 .env로 사용하세요

# Database (개발: SQLite, 프로덕션: PostgreSQL)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://artlink:password@localhost:5432/artlink"

# JWT
JWT_SECRET="your-secret-key-here"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# File Upload
UPLOAD_DIR="uploads"
